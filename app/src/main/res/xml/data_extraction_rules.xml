<?xml version="1.0" encoding="utf-8"?>
<!-- dataExtractionRules for Android 12+ -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="accounts_v2.enc" />
        <exclude domain="file" path="accounts_encrypted.json" />
        <exclude domain="file" path="accounts.json" />
        <exclude domain="file" path="settings.json" />
        <exclude domain="file" path="favorites.json" />
        <exclude domain="file" path="loved_tracks.json" />
        <exclude domain="file" path="last_played.txt" />
        <exclude domain="file" path="custom_playlists.json" />
        <exclude domain="file" path="adagiostream-debug.log" />
        <exclude domain="file" path="adagiostream-debug-prev.log" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="accounts_v2.enc" />
        <exclude domain="file" path="accounts_encrypted.json" />
        <exclude domain="file" path="accounts.json" />
    </device-transfer>
</data-extraction-rules>
