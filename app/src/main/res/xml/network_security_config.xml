<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        cleartextTrafficPermitted must remain true:

        - Xtream Codes servers may use HTTP-only endpoints.
        - Navidrome / Subsonic servers are most often self-hosted on a LAN
          (e.g. http://192.168.x.x:4533) with no TLS. Subsonic token auth sends
          t = MD5(password + salt), NEVER the plaintext password, so cleartext is
          acceptable at startup tier (PO decision, bead baw.1.6). The add/edit
          form shows a non-blocking "http is unencrypted" warning when the user
          enters an http:// URL.

        Hosts are user-entered at runtime, so per-domain scoping is not practical
        in static config; the global base-config follows the existing Xtream
        approach. OkHttp respects this setting on Android 9+.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
